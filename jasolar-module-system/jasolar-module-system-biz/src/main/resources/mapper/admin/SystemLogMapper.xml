<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jasolar.mis.module.system.mapper.admin.log.SystemLogMapper">



    <select id="logPage" resultType="com.jasolar.mis.module.system.controller.admin.log.resp.LogResp">
        select
            id,
            user_name userName,
            display_name displayName,
            ip,
            log_type logType,
            create_time createTime
        from system_log
        <where>
            deleted = 0
           <if test="search.userName != null and search.userName != '' ">
               and user_name like '%' || #{search.userName} || '%' ESCAPE '/'
           </if>
            <if test="search.logType != null and search.logType != '' ">
                and log_type like '%' || #{search.logType} || '%' ESCAPE '/'
            </if>
        </where>
        order by id desc
    </select>
</mapper>