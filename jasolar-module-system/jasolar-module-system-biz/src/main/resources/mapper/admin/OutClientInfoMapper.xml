<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jasolar.mis.module.system.mapper.admin.outer.OutClientInfoMapper">



    <select id="getClientInfo" resultType="com.jasolar.mis.module.system.oauth.ClientInfoResponse">

        select
            client_name,
            client_secret
        from out_client_info
        where client_name = #{clientName}

    </select>
</mapper>