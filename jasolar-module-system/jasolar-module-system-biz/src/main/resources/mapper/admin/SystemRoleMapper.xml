<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jasolar.mis.module.system.mapper.admin.role.SystemRoleMapper">


    <select id="getByUserGroupIds"
            resultType="com.jasolar.mis.module.system.controller.admin.role.resp.RoleSimpleResp">

        select
            distinct  ro.id,
            ro.code,
            ro.name
        from system_role ro
        inner join system_user_group_role_r r on r.role_id = ro.id and r.deleted = 0
        and ro.status = '1' and ro.deleted = 0
        where r.group_id in
        <foreach collection="groupIds" item="groupId" open="(" close=")" separator=",">
            #{groupId, jdbcType=BIGINT}
        </foreach>



    </select>
</mapper>

