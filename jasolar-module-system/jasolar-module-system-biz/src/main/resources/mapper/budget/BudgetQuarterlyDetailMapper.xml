        <result column="Q2_AMOUNT_ACTUAL" property="q2AmountActual"/>
        <result column="Q2_AMOUNT_ACTUAL_APPROVED" property="q2AmountActualApproved"/>
        <result column="Q2_AMOUNT_AVAILABLE" property="q2AmountAvailable"/>
