        <result column="MORG_CODE" property="morgCode"/>
        <result column="MORG_NAME" property="morgName"/>
        <result column="CUST1_CD" property="cust1Cd"/>
        <result column="CUST1_NAME" property="cust1Name"/>
        <result column="ACCOUNT_SUBJECT_CODE" property="accountSubjectCode"/>
        <result column="ACCOUNT_SUBJECT_NAME" property="accountSubjectName"/>
        <!-- Q1季度数据 -->
