    <!-- 通用查询条件 -->
    <sql id="whereClause">
        <where>
            <if test="year != null and year != ''">
                AND "YEAR" = #{year}
            </if>
            <if test="morgCode != null and morgCode != ''">
                AND "MORG_CODE" = #{morgCode}
            </if>
            <if test="cust1Cd != null and cust1Cd != ''">
                AND "CUST1_CD" = #{cust1Cd}
            </if>
            <if test="accountSubjectCode != null and accountSubjectCode != ''">
                AND "ACCOUNT_SUBJECT_CODE" = #{accountSubjectCode}
            </if>
        </where>
    </sql>

