        <result column="Q3_AMOUNT_ADJ" property="q3AmountAdj"/>
        <result column="Q3_TOTAL_BUDGET" property="q3TotalBudget"/>
        <result column="Q3_AMOUNT_FROZEN" property="q3AmountFrozen"/>
        <result column="Q3_AMOUNT_OCCUPIED" property="q3AmountOccupied"/>
        <result column="Q3_AMOUNT_ACTUAL" property="q3AmountActual"/>
        <result column="Q3_AMOUNT_ACTUAL_APPROVED" property="q3AmountActualApproved"/>
        <result column="Q3_AMOUNT_AVAILABLE" property="q3AmountAvailable"/>
        <!-- Q4季度数据 -->
        <result column="Q4_AMOUNT_TOTAL" property="q4AmountTotal"/>
        <result column="Q4_AMOUNT_ADJ" property="q4AmountAdj"/>
        <result column="Q4_TOTAL_BUDGET" property="q4TotalBudget"/>
        <result column="Q4_AMOUNT_FROZEN" property="q4AmountFrozen"/>
        <result column="Q4_AMOUNT_OCCUPIED" property="q4AmountOccupied"/>
        <result column="Q4_AMOUNT_ACTUAL" property="q4AmountActual"/>
