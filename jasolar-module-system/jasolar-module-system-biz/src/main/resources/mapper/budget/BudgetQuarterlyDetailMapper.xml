            "Q4_AMOUNT_ACTUAL",
            "Q4_AMOUNT_ACTUAL_APPROVED",
            "Q4_AMOUNT_AVAILABLE"
        FROM "V_BUDGET_QUARTERLY_DETAIL"
        <include refid="whereClause"/>
        ORDER BY "YEAR" DESC, "MORG_CODE", "CUST1_CD", "ACCOUNT_SUBJECT_CODE"
    </select>

    <!-- 通用查询条件（支持 BudgetBalanceQueryParams） -->
    <sql id="whereClauseByParams">
        <where>
            <if test="params.ehrCode != null and params.ehrCode != ''">
                AND MORG_CODE LIKE '%' || #{params.ehrCode} || '%'
            </if>
            <if test="params.ehrName != null and params.ehrName != ''">
                AND MORG_NAME LIKE '%' || #{params.ehrName} || '%'
            </if>
            <if test="params.customCode != null and params.customCode != ''">
                AND CUST1_CD LIKE '%' || #{params.customCode} || '%'
            </if>
            <if test="params.customName != null and params.customName != ''">
                AND CUST1_NAME LIKE '%' || #{params.customName} || '%'
            </if>
            <if test="params.accountSubjectCode != null and params.accountSubjectCode != ''">
                AND ACCOUNT_SUBJECT_CODE LIKE '%' || #{params.accountSubjectCode} || '%'
            </if>
            <if test="params.accountSubjectName != null and params.accountSubjectName != ''">
                AND ACCOUNT_SUBJECT_NAME LIKE '%' || #{params.accountSubjectName} || '%'
            </if>
            <if test="params.controlCust1Cd != null and params.controlCust1Cd != ''">
                AND CUST1_CD LIKE '%' || #{params.controlCust1Cd} || '%'
            </if>
            <if test="params.controlCust1Name != null and params.controlCust1Name != ''">
                AND CUST1_NAME LIKE '%' || #{params.controlCust1Name} || '%'
            </if>
            <if test="params.ehrCdList != null and params.ehrCdList.size() > 0">
                AND MORG_CODE IN
                <foreach collection="params.ehrCdList" item="ehrCd" open="(" separator="," close=")">
                    #{ehrCd}
                </foreach>
            </if>
            <!-- 
            注意：V_BUDGET_QUARTERLY_DETAIL 视图没有 PRJ_CD 字段，因此无法直接使用 PRJ_CD IN 查询。
            如果需要按项目编码过滤，可能需要通过其他方式实现（如关联其他视图）。
            目前先保留此条件，如果视图结构有变化可以启用。
            -->
            <!--
            <if test="params.prjCdList != null and params.prjCdList.size() > 0">
                AND PRJ_CD IN
                <foreach collection="params.prjCdList" item="prjCd" open="(" separator="," close=")">
                    #{prjCd}
                </foreach>
            </if>
            -->
        </where>
    </sql>

