            ACCOUNT_SUBJECT_CODE,
            ACCOUNT_SUBJECT_NAME,
            Q1_AMOUNT_TOTAL,
            Q1_AMOUNT_ADJ,
            Q1_TOTAL_BUDGET,
            Q1_AMOUNT_FROZEN,
            Q1_AMOUNT_OCCUPIED,
            Q1_AMOUNT_ACTUAL,
            Q1_AMOUNT_ACTUAL_APPROVED,
            Q1_AMOUNT_AVAILABLE,
            Q2_AMOUNT_TOTAL,
            Q2_AMOUNT_ADJ,
            Q2_TOTAL_BUDGET,
            Q2_AMOUNT_FROZEN,
            Q2_AMOUNT_OCCUPIED,
            Q2_AMOUNT_ACTUAL,
            Q2_AMOUNT_ACTUAL_APPROVED,
            Q2_AMOUNT_AVAILABLE,
            Q3_AMOUNT_TOTAL,
            Q3_AMOUNT_ADJ,
            Q3_TOTAL_BUDGET,
            Q3_AMOUNT_FROZEN,
            Q3_AMOUNT_OCCUPIED,
            Q3_AMOUNT_ACTUAL,
            Q3_AMOUNT_ACTUAL_APPROVED,
            Q3_AMOUNT_AVAILABLE,
            Q4_AMOUNT_TOTAL,
            Q4_AMOUNT_ADJ,
            Q4_TOTAL_BUDGET,
            Q4_AMOUNT_FROZEN,
            Q4_AMOUNT_OCCUPIED,
            Q4_AMOUNT_ACTUAL,
            Q4_AMOUNT_ACTUAL_APPROVED,
            Q4_AMOUNT_AVAILABLE
        FROM (
            SELECT 
                ROW_NUMBER() OVER (ORDER BY YEAR DESC, MORG_CODE, CUST1_CD, ACCOUNT_SUBJECT_CODE) AS rn,
                YEAR,
                MORG_CODE,
                MORG_NAME,
                CUST1_CD,
                CUST1_NAME,
                ACCOUNT_SUBJECT_CODE,
                ACCOUNT_SUBJECT_NAME,
                Q1_AMOUNT_TOTAL,
                Q1_AMOUNT_ADJ,
                Q1_TOTAL_BUDGET,
                Q1_AMOUNT_FROZEN,
                Q1_AMOUNT_OCCUPIED,
                Q1_AMOUNT_ACTUAL,
                Q1_AMOUNT_ACTUAL_APPROVED,
                Q1_AMOUNT_AVAILABLE,
                Q2_AMOUNT_TOTAL,
                Q2_AMOUNT_ADJ,
                Q2_TOTAL_BUDGET,
                Q2_AMOUNT_FROZEN,
                Q2_AMOUNT_OCCUPIED,
                Q2_AMOUNT_ACTUAL,
                Q2_AMOUNT_ACTUAL_APPROVED,
                Q2_AMOUNT_AVAILABLE,
                Q3_AMOUNT_TOTAL,
                Q3_AMOUNT_ADJ,
                Q3_TOTAL_BUDGET,
                Q3_AMOUNT_FROZEN,
                Q3_AMOUNT_OCCUPIED,
                Q3_AMOUNT_ACTUAL,
                Q3_AMOUNT_ACTUAL_APPROVED,
                Q3_AMOUNT_AVAILABLE,
                Q4_AMOUNT_TOTAL,
                Q4_AMOUNT_ADJ,
                Q4_TOTAL_BUDGET,
                Q4_AMOUNT_FROZEN,
                Q4_AMOUNT_OCCUPIED,
                Q4_AMOUNT_ACTUAL,
                Q4_AMOUNT_ACTUAL_APPROVED,
                Q4_AMOUNT_AVAILABLE
            FROM V_BUDGET_QUARTERLY_DETAIL
            <include refid="whereClauseByParams"/>
        ) t
        WHERE t.rn BETWEEN #{startRow} AND #{endRow}
    </select>

    <!-- 查询总数（支持 BudgetBalanceQueryParams） -->
    <select id="selectCountByParams" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM V_BUDGET_QUARTERLY_DETAIL
        <include refid="whereClauseByParams"/>
    </select>

