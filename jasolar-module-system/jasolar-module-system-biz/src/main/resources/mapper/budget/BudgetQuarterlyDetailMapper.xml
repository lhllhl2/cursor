        <result column="Q1_AMOUNT_ADJ" property="q1AmountAdj"/>
        <result column="Q1_TOTAL_BUDGET" property="q1TotalBudget"/>
        <result column="Q1_AMOUNT_FROZEN" property="q1AmountFrozen"/>
        <result column="Q1_AMOUNT_OCCUPIED" property="q1AmountOccupied"/>
