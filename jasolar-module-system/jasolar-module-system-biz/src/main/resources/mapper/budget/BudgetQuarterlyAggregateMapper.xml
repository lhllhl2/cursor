    <!-- 通用查询条件 -->
    <sql id="whereClause">
        <where>
            <if test="year != null and year != ''">
                AND "YEAR" = #{year}
            </if>
            <if test="ehrErpAcctCd != null and ehrErpAcctCd != ''">
                AND "EHR_ERP_ACCT_CD" = #{ehrErpAcctCd}
            </if>
            <if test="controlEhrCode != null and controlEhrCode != ''">
                AND "CONTROL_EHR_CODE" = #{controlEhrCode}
            </if>
            <if test="controlCust1Cd != null and controlCust1Cd != ''">
                AND "CONTROL_CUST1_CD" = #{controlCust1Cd}
            </if>
            <if test="controlAccountSubjectCode != null and controlAccountSubjectCode != ''">
                AND "CONTROL_ACCOUNT_SUBJECT_CODE" = #{controlAccountSubjectCode}
            </if>
        </where>
    </sql>

