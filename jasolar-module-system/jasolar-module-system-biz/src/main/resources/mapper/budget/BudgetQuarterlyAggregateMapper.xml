                Q4_AMOUNT_AVAILABLE
            FROM V_BUDGET_QUARTERLY_AGGREGATE_OPTIMIZED
            <include refid="whereClauseByParams"/>
        ) t
        WHERE t.rn BETWEEN #{startRow} AND #{endRow}
    </select>

