              AND (year, quarter, is_internal, morg_code, budget_subject_code, master_project_code, erp_asset_type) IN
              <foreach collection="dimensionParams" item="item" separator="," open="(" close=")">
                  (#{item.year}, #{item.quarter}, #{item.isInternal}, #{item.morgCode}, #{item.budgetSubjectCode}, #{item.masterProjectCode}, #{item.erpAssetType})
              </foreach>
        </if>
