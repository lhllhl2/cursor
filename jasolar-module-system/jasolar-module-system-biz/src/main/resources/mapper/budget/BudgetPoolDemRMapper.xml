<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jasolar.mis.module.system.mapper.budget.BudgetPoolDemRMapper">

    <select id="selectByDimensions"
            parameterType="java.util.List"
            resultType="com.jasolar.mis.module.system.domain.budget.BudgetPoolDemR">
        <if test="details == null or details.size == 0">
            SELECT *
            FROM budget_pool_dem_r
            WHERE 1 = 0
        </if>
        <if test="details != null and details.size > 0">
            SELECT *
            FROM budget_pool_dem_r
            WHERE deleted = 0
              AND (year, quarter, morg_code, budget_subject_code, master_project_code) IN
              <foreach collection="details" item="item" separator="," open="(" close=")">
                  (#{item.year}, #{item.quarter}, #{item.managementOrg}, #{item.budgetSubjectCode}, #{item.masterProjectCode})
              </foreach>
        </if>
    </select>

    <select id="selectByDimensionsForContract"
            parameterType="java.util.List"
